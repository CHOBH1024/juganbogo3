# ──────────────────────────────────────────────────────────────────────────────
# Google AI Studio Build 앱 Secrets 설정 목록
# AI Studio 앱 편집기 → 우측 상단 [Secrets] 탭에서 등록
# ──────────────────────────────────────────────────────────────────────────────

# [자동 주입] AI Studio가 배포 시 자동으로 채워주는 값 — 수동 입력 불필요
GEMINI_API_KEY="(AI Studio 자동 주입)"
APP_URL="(AI Studio 자동 주입 — Cloud Run 서비스 URL)"

# ── Google Drive 자동 업로드 설정 ──────────────────────────────────────────────
# 설정 방법: 관리자 취합 콘솔 → [Drive 연동 설정 가이드] 버튼 참고

# Step 1: Google Cloud Console에서 OAuth 클라이언트 생성 후 아래 두 값 입력
GOOGLE_CLIENT_ID="YOUR_OAUTH_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_OAUTH_CLIENT_SECRET"

# Step 2: 앱 배포 후 관리자 콘솔에서 "구글 계정 인증하기" 클릭 → 발급된 토큰 입력
GOOGLE_REFRESH_TOKEN=""

# Step 3 (선택): 업로드할 Drive 폴더 ID
# Drive 폴더 URL: https://drive.google.com/drive/folders/[여기가 ID]
# 비워두면 내 드라이브에 '주간보고_제출현황' 폴더가 자동 생성됩니다
GOOGLE_DRIVE_FOLDER_ID=""
