# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# 로컬: http://localhost:5000 / 배포 시 실제 도메인 URL
APP_URL="http://localhost:5000"

# ── Google Drive API ────────────────────────────────────────────────────────
# 1. https://console.cloud.google.com 에서 프로젝트 생성
# 2. API 및 서비스 → Drive API 활성화
# 3. 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 생성 (웹 애플리케이션)
#    승인된 리디렉션 URI: http://localhost:5000/api/google-auth/callback
# 4. 아래 두 값 입력 후 서버 시작
# 5. 브라우저에서 http://localhost:5000/api/google-auth 접속 → 구글 계정 허용
# 6. 화면에 표시된 REFRESH_TOKEN을 아래에 붙여넣기 후 서버 재시작

GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# 최초 /api/google-auth 인증 후 발급받은 토큰을 여기에 저장
GOOGLE_REFRESH_TOKEN=""

# (선택) 업로드할 Drive 폴더 ID — 비워두면 내 드라이브 루트에 '주간보고_제출현황' 폴더 자동 생성
# Drive 폴더 URL: https://drive.google.com/drive/folders/[여기가 ID]
GOOGLE_DRIVE_FOLDER_ID=""
